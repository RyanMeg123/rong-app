generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  blocked
  deleted
}

enum IdentityProvider {
  apple
  email
  guest
}

enum RoleStatus {
  active
  inactive
}

enum ConversationStatus {
  active
  closed
  archived
}

enum SenderType {
  user
  assistant
  system
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum SafetyDecision {
  allow
  rewrite
  block
  support_prompt
}

model User {
  id             String            @id @default(uuid()) @db.Uuid
  status         UserStatus
  isGuest        Boolean           @default(true) @map("is_guest")
  nickname       String?           @db.VarChar(50)
  avatarUrl      String?           @map("avatar_url")
  defaultRoleId  String?           @map("default_role_id") @db.Uuid
  lastActiveAt   DateTime?         @map("last_active_at") @db.Timestamptz(6)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?         @map("deleted_at") @db.Timestamptz(6)
  defaultRole    Role?             @relation("UserDefaultRole", fields: [defaultRoleId], references: [id])
  authIdentities AuthIdentity[]
  roleStates     UserRoleState[]
  conversations  Conversation[]
  memoryCards    MemoryCard[]
  safetyEvents   SafetyEvent[]
  refreshTokens  RefreshToken[]

  @@index([status], map: "idx_users_status")
  @@index([lastActiveAt], map: "idx_users_last_active_at")
  @@map("users")
}

model AuthIdentity {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  provider     IdentityProvider
  providerUid  String           @map("provider_uid") @db.VarChar(255)
  email        String?          @db.VarChar(255)
  isPrimary    Boolean          @default(false) @map("is_primary")
  verifiedAt   DateTime?        @map("verified_at") @db.Timestamptz(6)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid], map: "uk_auth_identities_provider_uid")
  @@index([userId], map: "idx_auth_identities_user_id")
  @@index([email], map: "idx_auth_identities_email")
  @@map("auth_identities")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique @db.VarChar(50)
  name            String           @db.VarChar(50)
  subtitle        String           @db.VarChar(100)
  personaSummary  String           @map("persona_summary")
  toneRules       Json             @map("tone_rules")
  boundaryRules   Json             @map("boundary_rules")
  sortOrder       Int              @default(0) @map("sort_order")
  status          RoleStatus
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  defaultForUsers User[]           @relation("UserDefaultRole")
  roleStates      UserRoleState[]
  conversations   Conversation[]
  memoryCards     MemoryCard[]

  @@index([status], map: "idx_roles_status")
  @@index([sortOrder], map: "idx_roles_sort_order")
  @@map("roles")
}

model UserRoleState {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  roleId           String    @map("role_id") @db.Uuid
  relationshipStage String   @map("relationship_stage") @db.VarChar(30)
  affinityScore    Int       @default(0) @map("affinity_score")
  lastTopic        String?   @map("last_topic") @db.VarChar(100)
  lastComfortStyle String?   @map("last_comfort_style") @db.VarChar(50)
  lastInteractedAt DateTime? @map("last_interacted_at") @db.Timestamptz(6)
  memoryVersion    Int       @default(1) @map("memory_version")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role             Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId], map: "uk_user_role_states_user_role")
  @@index([userId], map: "idx_user_role_states_user_id")
  @@index([roleId], map: "idx_user_role_states_role_id")
  @@index([lastInteractedAt], map: "idx_user_role_states_last_interacted_at")
  @@map("user_role_states")
}

model Conversation {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  roleId        String          @map("role_id") @db.Uuid
  status        ConversationStatus
  startedAt     DateTime        @map("started_at") @db.Timestamptz(6)
  endedAt       DateTime?       @map("ended_at") @db.Timestamptz(6)
  messageCount  Int             @default(0) @map("message_count")
  lastMessageAt DateTime?       @map("last_message_at") @db.Timestamptz(6)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  messages      Message[]
  memoryCards   MemoryCard[]
  safetyEvents  SafetyEvent[]

  @@index([userId, status], map: "idx_conversations_user_status")
  @@index([lastMessageAt], map: "idx_conversations_last_message_at")
  @@map("conversations")
}

model Message {
  id             String        @id @default(uuid()) @db.Uuid
  conversationId String        @map("conversation_id") @db.Uuid
  senderType     SenderType    @map("sender_type")
  content        String
  contentSummary String?       @map("content_summary") @db.VarChar(255)
  riskLevel      RiskLevel     @default(low) @map("risk_level")
  blockedReason  String?       @map("blocked_reason") @db.VarChar(100)
  modelLatencyMs Int?          @map("model_latency_ms")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt      DateTime      @map("expires_at") @db.Timestamptz(6)
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  safetyEvents   SafetyEvent[]

  @@index([conversationId, createdAt], map: "idx_messages_conversation_created_at")
  @@index([expiresAt], map: "idx_messages_expires_at")
  @@map("messages")
}

model MemoryCard {
  id                   String         @id @default(uuid()) @db.Uuid
  userId               String         @map("user_id") @db.Uuid
  roleId               String         @map("role_id") @db.Uuid
  memoryType           String         @map("memory_type") @db.VarChar(50)
  memoryKey            String         @map("memory_key") @db.VarChar(100)
  memoryValue          String         @map("memory_value")
  sourceConversationId String?        @map("source_conversation_id") @db.Uuid
  consentScope         String         @map("consent_scope") @db.VarChar(30)
  confidenceScore      Decimal        @default(0.80) @map("confidence_score") @db.Decimal(4, 2)
  isActive             Boolean        @default(true) @map("is_active")
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  expiredAt            DateTime?      @map("expired_at") @db.Timestamptz(6)
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                 Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)
  sourceConversation   Conversation?  @relation(fields: [sourceConversationId], references: [id], onDelete: SetNull)

  @@unique([userId, roleId, memoryKey], map: "uk_memory_cards_user_role_key")
  @@index([userId, roleId], map: "idx_memory_cards_user_role")
  @@index([memoryType], map: "idx_memory_cards_memory_type")
  @@index([isActive], map: "idx_memory_cards_is_active")
  @@map("memory_cards")
}

model SafetyEvent {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  conversationId String?        @map("conversation_id") @db.Uuid
  messageId      String?        @map("message_id") @db.Uuid
  riskType       String         @map("risk_type") @db.VarChar(50)
  riskLevel      RiskLevel      @map("risk_level")
  decision       SafetyDecision
  handlerVersion String         @map("handler_version") @db.VarChar(20)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message        Message?       @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId], map: "idx_safety_events_user_id")
  @@index([riskType], map: "idx_safety_events_risk_type")
  @@index([createdAt], map: "idx_safety_events_created_at")
  @@map("safety_events")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  deviceId   String?   @map("device_id") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@index([expiresAt], map: "idx_refresh_tokens_expires_at")
  @@map("refresh_tokens")
}
